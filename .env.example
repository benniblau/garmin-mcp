# =============================================================================
# STRAVA API CREDENTIALS
# =============================================================================
# Get these from https://www.strava.com/settings/api

STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# OAuth Tokens (you need either access_token OR refresh_token, preferably both)
STRAVA_ACCESS_TOKEN=your_access_token_here
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# Token Setup Instructions:
# 1. Go to https://www.strava.com/settings/api
# 2. Create an application if you haven't already
# 3. Get authorization code using OAuth flow:
#    https://www.strava.com/oauth/authorize?client_id=YOUR_CLIENT_ID&redirect_uri=http://localhost&response_type=code&scope=activity:read_all
# 4. Exchange authorization code for tokens:
#    POST https://www.strava.com/oauth/token
#    - client_id=YOUR_CLIENT_ID
#    - client_secret=YOUR_CLIENT_SECRET  
#    - code=AUTHORIZATION_CODE
#    - grant_type=authorization_code
# 5. This will give you both access_token and refresh_token
#
# Note: Access tokens expire after 6 hours, refresh tokens are used to get new access tokens
# The script will automatically refresh expired tokens if you have a refresh_token

# =============================================================================
# GARMIN CONNECT CREDENTIALS
# =============================================================================
# Use your Garmin Connect login credentials

GARMIN_USERNAME=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password

# Optional: Set start date for initial sync (YYYY-MM-DD format)
# If not set, defaults to last 2 years of activities
GARMIN_START_DATE=2020-01-01

# Note: Garmin credentials are valid for 1 year after login
# The python-garminconnect library handles authentication automatically

# =============================================================================
# MCP SERVER HTTP TRANSPORT
# =============================================================================
# Set to "http" to run in HTTP mode (default: "stdio" for local Claude Desktop)
MCP_TRANSPORT=http

# Required for HTTP mode: bearer token for authentication
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=your_generated_token_here

# HTTP bind address and port
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080